#!/usr/bin/env bash
# Run Cucumber integration tests against real FE + BE servers.
#
# Usage:
#   bin/run_cucumber_tests              # use default ports
#   BE_URL=http://localhost:3969 \
#   FE_URL=http://localhost:3001 \
#   bin/run_cucumber_tests [cucumber args]
#
# Before running, ensure:
#   Terminal 1: RAILS_ENV=test bundle exec rails server -p 3969
#   Terminal 2: RAILS_ENV=test bundle exec sidekiq
#   Terminal 3: cd frontend && npm run dev   (or npm run build + rails server serves it)

set -e

BE_URL="${BE_URL:-http://localhost:3969}"
FE_URL="${FE_URL:-http://localhost:3001}"
PIDS_TO_KILL=()

log()  { echo "==> $*"; }
fail() { echo "ERROR: $*" >&2; exit 1; }

check_server() {
  local name=$1 url=$2
  if curl -sf --max-time 3 "$url" -o /dev/null 2>/dev/null; then
    log "$name is up at $url"
    return 0
  else
    return 1
  fi
}

# ── Auto-start BE in test mode if not running ─────────────────────────────────
if ! check_server "Backend" "$BE_URL/api/v1/videos"; then
  log "Starting Rails backend in test mode on port 3969..."
  RAILS_ENV=test bundle exec rails db:migrate 2>/dev/null || true
  RAILS_ENV=test bundle exec rails server -p 3969 -d \
    --pid tmp/pids/cucumber_be.pid > log/cucumber_be.log 2>&1
  sleep 4
  check_server "Backend" "$BE_URL/api/v1/videos" \
    || fail "Backend failed to start. Check log/cucumber_be.log"
  PIDS_TO_KILL+=("tmp/pids/cucumber_be.pid")
fi

# ── Check Sidekiq (needed for real-time notifications) ────────────────────────
if ! pgrep -f "sidekiq" > /dev/null 2>&1; then
  log "Starting Sidekiq in test mode..."
  RAILS_ENV=test bundle exec sidekiq -d \
    -P tmp/pids/cucumber_sidekiq.pid \
    -L log/cucumber_sidekiq.log 2>/dev/null || true
  sleep 2
  PIDS_TO_KILL+=("tmp/pids/cucumber_sidekiq.pid")
fi

# ── FE must be running (Vite dev server) ─────────────────────────────────────
check_server "Frontend" "$FE_URL" \
  || fail "Frontend not running at $FE_URL.\nStart with: cd frontend && npm run dev"

# ── Build frontend into public/ for cucumber (SPA is served via proxy) ────────
log "Running Cucumber tests..."
RAILS_ENV=test FE_URL="$FE_URL" BE_URL="$BE_URL" bundle exec cucumber "$@"
EXIT_CODE=$?

# ── Cleanup servers we started ───────────────────────────────────────────────
for pid_file in "${PIDS_TO_KILL[@]}"; do
  if [ -f "$pid_file" ]; then
    pid=$(cat "$pid_file")
    kill "$pid" 2>/dev/null && log "Stopped process $pid ($pid_file)" || true
    rm -f "$pid_file"
  fi
done

exit $EXIT_CODE
