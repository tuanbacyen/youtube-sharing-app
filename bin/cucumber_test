#!/usr/bin/env bash
# Run Cucumber tests against the running test Docker environment.
# Requires bin/cucumber_start to have been run first.
#
# Usage:
#   bin/cucumber_test                            # run all features
#   bin/cucumber_test features/notifications.feature
#   bin/cucumber_test features/auth.feature features/share_video.feature
set -e
export COMPOSE_PROJECT_NAME=remitano-interview-test

FE_URL="http://localhost:3100"
TEST_DB_URL="postgres://postgres:password@localhost:5433/remitano_interview_test"

log() { echo "==> $*"; }

log "Running Cucumber tests..."
set +e
RAILS_ENV=test \
  DATABASE_URL="$TEST_DB_URL" \
  FE_URL="$FE_URL" \
  bundle exec cucumber "$@"
EXIT_CODE=$?
set -e

exit $EXIT_CODE
