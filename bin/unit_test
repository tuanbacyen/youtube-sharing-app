#!/usr/bin/env bash
# Run RSpec unit/request tests inside Docker using RAILS_ENV=test.
# Starts db + redis if not running, then prepares the test database.
set -e

# Ensure db and redis are up
if ! docker compose ps db 2>/dev/null | grep -q "running\|healthy"; then
  echo "==> Starting db and redis..."
  docker compose up -d db redis
  sleep 4
fi

echo "==> Preparing test database..."
docker compose run --rm \
  -e RAILS_ENV=test \
  backend bundle exec rails db:prepare

echo "==> Running RSpec (RAILS_ENV=test)..."
docker compose run --rm \
  -e RAILS_ENV=test \
  backend bundle exec rspec "$@"
